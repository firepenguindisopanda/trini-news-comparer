# LLM PROVIDERS

# NVIDIA_NIM_API_KEY: Primary LLM provider - multi-agent pipeline.
# Powers the 5-agent pipeline: TopicExpander to ArticleMatcher to SourceAnalyst
# to CrossSourceSynthesizer to Verifier.
NVIDIA_NIM_API_KEY="nvapi-..."

# Optional: Per-agent model overrides for the NVIDIA multi-agent pipeline.
# Defaults use a tiered strategy (70B for reasoning, 8B for parallel analysis,
# 340B fallback synthesizer). Only uncomment these to override.
# NVIDIA_EXPANDER_MODEL="meta/llama-3.1-70b-instruct"
# NVIDIA_MATCHER_MODEL="meta/llama-3.1-70b-instruct"
# NVIDIA_ANALYST_MODEL="meta/llama-3.1-8b-instruct"
# NVIDIA_SYNTHESIZER_MODEL="meta/llama-3.1-70b-instruct"
# NVIDIA_FALLBACK_SYNTHESIZER_MODEL="nvidia/nemotron-4-340b-instruct"
# NVIDIA_VERIFIER_MODEL="meta/llama-3.1-70b-instruct"

# UPSTASH REDIS (Caching + Rate Limiting)
# Required. Get these from your Upstash console.
UPSTASH_REDIS_URL="https://your-redis-endpoint.upstash.io"
UPSTASH_REDIS_TOKEN="your-redis-token"

# PUSHER CHANNELS (Real-time WebSocket Progress)
# Required for real-time progress events from the comparison runner.
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="us2"
VITE_PUSHER_KEY="your-pusher-key"
VITE_PUSHER_CLUSTER="us2"

# APP CONFIG
APP_URL="http://localhost:3000"

# WORKER
# How often the background worker scrapes all sources (in minutes).
WORKER_SCRAPE_INTERVAL_MINUTES=60

# RATE LIMITS
# RATE_COMPARE_PER_MINUTE=10
# CACHE_SCRAPE_TTL=300
# CACHE_COMPARE_TTL=86400
